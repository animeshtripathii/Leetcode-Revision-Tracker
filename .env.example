# MongoDB Connection
MONGODB_URI=mongodb://localhost:27017/leetcode-tracker

# JWT Secret (Change this to a random string)
JWT_SECRET=your-super-secret-jwt-key-change-this

# Email Configuration (Gmail example)
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-app-password

# Server Port
PORT=5000

# Instructions:
# 1. For Gmail, you need to generate an "App Password":
#    - Go to Google Account Settings > Security
#    - Enable 2-Step Verification
#    - Go to App Passwords and generate one for "Mail"
#    - Use that password in EMAIL_PASS
# 2. Generate a strong random string for JWT_SECRET
# 3. Update MONGODB_URI if using cloud MongoDB (Atlas)
